{
  "info": {
    "name": "Findea API",
    "description": "Complete API collection for the Findea e-commerce backend.\n\n**Base URL:** `http://209.74.71.27:4000/api`\n\n**Quick start:**\n1. Run \"Login as Customer\" — `accessToken` is saved automatically.\n2. Run \"Login as Admin\" — `adminToken` is saved automatically.\n3. All auth-protected requests use the saved tokens via collection variables.\n\n**Seed credentials:**\n- Admin: `admin@fidea.com` / `Admin@12345`\n- Customer: `sarah@example.com` / `Customer@12345`\n\n**Test coupons:** `WELCOME10`, `FLAT500`, `SUMMER15`, `DEVTEST`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://209.74.71.27:4000/api", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "adminToken",   "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "productId",    "value": "", "type": "string" },
    { "key": "productSlug",  "value": "linen-wrap-dress", "type": "string" },
    { "key": "orderId",      "value": "", "type": "string" },
    { "key": "orderNumber",  "value": "", "type": "string" },
    { "key": "addressId",    "value": "", "type": "string" },
    { "key": "cartItemId",   "value": "", "type": "string" },
    { "key": "couponId",     "value": "", "type": "string" },
    { "key": "reviewId",     "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Test@12345\",\n  \"firstName\": \"New\",\n  \"lastName\": \"User\",\n  \"phone\": \"+8801700000001\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', r.accessToken);",
                "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
                "  console.log('accessToken saved:', r.accessToken?.substring(0,20) + '...');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login as Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sarah@example.com\",\n  \"password\": \"Customer@12345\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', r.accessToken);",
                "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
                "  console.log('Customer token saved');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fidea.com\",\n  \"password\": \"Admin@12345\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('adminToken', r.accessToken);",
                "  console.log('Admin token saved');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', r.accessToken);",
                "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sarah@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password (OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/reset-password-otp", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sarah@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPass@123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
