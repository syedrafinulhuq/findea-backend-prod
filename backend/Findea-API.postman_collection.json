          }
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/users/me/addresses/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["users", "me", "addresses", "{{addressId}}"] }
          }
        }
      ]
    },
    {
