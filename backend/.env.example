NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/findea?schema=public

# JWT
JWT_ACCESS_SECRET=replace-me-with-at-least-32-random-chars
JWT_REFRESH_SECRET=replace-me-with-a-different-32-random-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (required by BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Fidea <no-reply@fidea.com>"

# Frontend
FRONTEND_URL=http://localhost:3000
# Production: comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_xxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_xxx
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TEST_ENCRYPTION_xxx
FLUTTERWAVE_WEBHOOK_HASH=replace-me-webhook-hash

# Inventory
LOW_STOCK_THRESHOLD=5
